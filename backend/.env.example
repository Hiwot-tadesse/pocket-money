# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/pocket-money

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend base URL for password reset links
FRONTEND_URL=http://localhost:19006

# Password reset token configuration
RESET_TOKEN_EXPIRES_MS=3600000
RESET_TOKEN_EXPIRES_LABEL=1 hour
RESET_MAX_ATTEMPTS=5
RESET_ATTEMPT_WINDOW_MS=900000
RESET_BLOCK_DURATION_MS=900000

# SMTP Email (for password reset & welcome emails)
# Gmail example: use an App Password (not your account password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_NAME=Pocket Money

# Receipt OCR (OCR.Space API key)
OCR_API_KEY=your_ocr_space_api_key

# Login attempt throttling (optional)
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_BLOCK_DURATION_MS=900000

# AI Chat (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
